#!/usr/bin/env node

/*
 * git-move-branches - Fix up branches after git-branchless move
 *
 * After running `git move`, branches may remain pointing at old (orphaned)
 * commits instead of the newly-created equivalent commits. This command
 * detects that situation and relocates branches to the correct commits.
 *
 * Detection algorithm:
 * 1. Get stack commits via stack() — these are the move destinations
 * 2. Get all branches on draft commits via draft() — includes orphaned branches
 * 3. Filter to branches whose commit is NOT in the stack (orphaned)
 * 4. Match orphaned branches to stack commits by commit message
 * 5. When multiple commits share a message, pair by timestamp order
 *    (Nth-oldest orphan → Nth-oldest stack commit)
 * 6. Preserve remote tracking info
 */

const { execSync } = require('child_process')

function run(cmd, options = {}) {
  try {
    return execSync(cmd, { encoding: 'utf8', ...options }).trim()
  } catch (e) {
    if (options.allowFailure) return null
    throw e
  }
}

function getStackCommits() {
  // Get all commits in the stack with their messages
  // Format: "shorthash message"
  const output = run("git query 'stack()'")
  if (!output) return []

  const commits = []
  for (const line of output.split('\n')) {
    if (!line.trim()) continue
    const spaceIdx = line.indexOf(' ')
    if (spaceIdx === -1) continue

    const shortHash = line.slice(0, spaceIdx)
    const message = line.slice(spaceIdx + 1)
    // Expand to full hash for consistent comparison
    const hash = run(`git rev-parse ${shortHash}`)
    commits.push({ hash, message })
  }
  return commits
}

function getBranchesOnDrafts() {
  // Get all branch names on draft commits (includes orphaned commits from moves)
  const output = run("git query -b 'draft()'", { allowFailure: true })
  if (!output) return new Map()

  const branches = new Map()
  for (const line of output.split('\n')) {
    const branch = line.trim()
    if (!branch) continue

    const hash = run(`git rev-parse ${branch}`)
    const message = run(`git log -1 --format="%s" ${hash}`)
    const remote = run(`git config branch.${branch}.remote`, { allowFailure: true })
    const merge = run(`git config branch.${branch}.merge`, { allowFailure: true })

    branches.set(branch, { hash, message, remote, merge })
  }
  return branches
}

function getCommitTimestamp(hash) {
  // Get committer timestamp (unix epoch)
  return parseInt(run(`git log -1 --format="%ct" ${hash}`), 10)
}

function findBranchesToMove(stackCommits, draftBranches) {
  const stackHashes = new Set(stackCommits.map(c => c.hash))

  // Build map: message → [hashes] sorted by timestamp for stack commits
  const stackByMessage = new Map()
  for (const commit of stackCommits) {
    if (!stackByMessage.has(commit.message)) {
      stackByMessage.set(commit.message, [])
    }
    stackByMessage.get(commit.message).push(commit.hash)
  }
  // Sort each group by timestamp (oldest first) for positional matching
  for (const [, hashes] of stackByMessage) {
    hashes.sort((a, b) => getCommitTimestamp(a) - getCommitTimestamp(b))
  }

  // Find branches on draft commits that are NOT in the stack (orphaned)
  const candidates = []
  for (const [branch, info] of draftBranches) {
    if (!stackHashes.has(info.hash)) {
      candidates.push({ branch, ...info })
    }
  }

  if (candidates.length === 0) return []

  // Track how many candidates with each message we've matched,
  // so Nth-oldest orphan maps to Nth-oldest stack commit
  const matchCount = new Map()

  // Sort candidates by timestamp (oldest first) for positional pairing
  candidates.sort((a, b) => getCommitTimestamp(a.hash) - getCommitTimestamp(b.hash))

  const toMove = []
  for (const candidate of candidates) {
    const targets = stackByMessage.get(candidate.message)
    if (!targets || targets.length === 0) continue

    const idx = matchCount.get(candidate.message) || 0
    if (idx >= targets.length) continue // more orphans than targets, skip

    matchCount.set(candidate.message, idx + 1)

    toMove.push({
      branch: candidate.branch,
      from: candidate.hash,
      to: targets[idx],
      remote: candidate.remote,
      merge: candidate.merge,
      message: candidate.message,
    })
  }

  return toMove
}

function main() {
  const args = process.argv.slice(2)
  const dryRun = args.includes('-n') || args.includes('--dry-run')

  if (args.includes('-h') || args.includes('--help')) {
    console.log(`Usage: git move-branches [options]

Fix up branches after git-branchless move.

After running 'git move', branches may remain pointing at old commits
instead of the newly-created equivalent commits. This command detects
duplicate commit messages in the stack and moves branches to the new commits.

Options:
  -n, --dry-run    Show what would be done without executing
  -h, --help       Show this help message

Example:
  git move -s 'stack()' -d main   # Run the move
  git move-branches               # Fix up the branches
`)
    process.exit(0)
  }

  console.log('Scanning stack for branches to relocate...')

  const commits = getStackCommits()
  const branches = getBranchesOnDrafts()
  const toMove = findBranchesToMove(commits, branches)

  if (toMove.length === 0) {
    console.log('No branches need to be relocated.')
    process.exit(0)
  }

  console.log(`Found ${toMove.length} branch(es) to relocate:`)
  for (const m of toMove) {
    const tracking = m.remote ? ` (tracks ${m.remote}/${m.merge?.replace('refs/heads/', '')})` : ''
    console.log(`  ${m.branch}: ${m.from.slice(0, 7)} -> ${m.to.slice(0, 7)}${tracking}`)
    console.log(`    "${m.message}"`)
  }

  if (dryRun) {
    console.log('\n(dry-run mode, no changes made)')
    process.exit(0)
  }

  console.log('\nRelocating branches...')
  for (const m of toMove) {
    // Delete old branch and create at new location
    run(`git branch -D ${m.branch}`)
    run(`git branch ${m.branch} ${m.to}`)

    // Restore tracking info if it existed
    if (m.remote) {
      run(`git config branch.${m.branch}.remote ${m.remote}`)
    }
    if (m.merge) {
      run(`git config branch.${m.branch}.merge ${m.merge}`)
    }

    console.log(`  ✓ ${m.branch}`)
  }

  console.log('\nDone!')
}

main()
